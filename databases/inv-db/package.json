{
  "name": "@beezone/inv-db",
  "description": "inv-db prisma orm project",
  "version": "0.0.5",
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  },
  "homepage": "https://beemood.github.io/beezone/databases/inv-db",
  "icon": "https://beemood.github.io/beezone/databases/inv-db/assets/favicon.png",
  "author": {
    "email": "robert.brightline@gmail.com",
    "name": "Robert Brightline",
    "url": "https://beemood.github.io"
  },
  "funding": [
    "https://cash.app/$puqlib"
  ],
  "keywords": [
    "database",
    "prisma"
  ],
  "files": [
    "prisma",
    "scripts",
    "!**/*.tsbuildinfo"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "browser": "dist/index-browser.js",
  "exports": {
    "./client": {
      "require": {
        "node": "./dist/index.js",
        "edge-light": "./dist/wasm.js",
        "workerd": "./dist/wasm.js",
        "worker": "./dist/wasm.js",
        "browser": "./dist/index-browser.js",
        "default": "./dist/index.js"
      },
      "import": {
        "node": "./dist/index.js",
        "edge-light": "./dist/wasm.js",
        "workerd": "./dist/wasm.js",
        "worker": "./dist/wasm.js",
        "browser": "./dist/index-browser.js",
        "default": "./dist/index.js"
      },
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json",
    ".": {
      "require": {
        "node": "./dist/index.js",
        "edge-light": "./dist/wasm.js",
        "workerd": "./dist/wasm.js",
        "worker": "./dist/wasm.js",
        "browser": "./dist/index-browser.js",
        "default": "./dist/index.js"
      },
      "import": {
        "node": "./dist/index.js",
        "edge-light": "./dist/wasm.js",
        "workerd": "./dist/wasm.js",
        "worker": "./dist/wasm.js",
        "browser": "./dist/index-browser.js",
        "default": "./dist/index.js"
      },
      "default": "./dist/index.js"
    },
    "./edge": {
      "types": "./dist/edge.d.ts",
      "require": "./dist/edge.js",
      "import": "./dist/edge.js",
      "default": "./dist/edge.js"
    },
    "./react-native": {
      "types": "./dist/react-native.d.ts",
      "require": "./dist/react-native.js",
      "import": "./dist/react-native.js",
      "default": "./dist/react-native.js"
    },
    "./extension": {
      "types": "./dist/extension.d.ts",
      "require": "./dist/extension.js",
      "import": "./dist/extension.js",
      "default": "./dist/extension.js"
    },
    "./index-browser": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index-browser.js",
      "import": "./dist/index-browser.js",
      "default": "./dist/index-browser.js"
    },
    "./index": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./wasm": {
      "types": "./dist/wasm.d.ts",
      "require": "./dist/wasm.js",
      "import": "./dist/wasm.mjs",
      "default": "./dist/wasm.mjs"
    },
    "./runtime/client": {
      "types": "./dist/runtime/client.d.ts",
      "node": {
        "require": "./dist/runtime/client.js",
        "default": "./dist/runtime/client.js"
      },
      "require": "./dist/runtime/client.js",
      "import": "./dist/runtime/client.mjs",
      "default": "./dist/runtime/client.mjs"
    },
    "./runtime/library": {
      "types": "./dist/runtime/library.d.ts",
      "require": "./dist/runtime/library.js",
      "import": "./dist/runtime/library.mjs",
      "default": "./dist/runtime/library.mjs"
    },
    "./runtime/binary": {
      "types": "./dist/runtime/binary.d.ts",
      "require": "./dist/runtime/binary.js",
      "import": "./dist/runtime/binary.mjs",
      "default": "./dist/runtime/binary.mjs"
    },
    "./runtime/wasm-engine-edge": {
      "types": "./dist/runtime/wasm-engine-edge.d.ts",
      "require": "./dist/runtime/wasm-engine-edge.js",
      "import": "./dist/runtime/wasm-engine-edge.mjs",
      "default": "./dist/runtime/wasm-engine-edge.mjs"
    },
    "./runtime/wasm-compiler-edge": {
      "types": "./dist/runtime/wasm-compiler-edge.d.ts",
      "require": "./dist/runtime/wasm-compiler-edge.js",
      "import": "./dist/runtime/wasm-compiler-edge.mjs",
      "default": "./dist/runtime/wasm-compiler-edge.mjs"
    },
    "./runtime/edge": {
      "types": "./dist/runtime/edge.d.ts",
      "require": "./dist/runtime/edge.js",
      "import": "./dist/runtime/edge-esm.js",
      "default": "./dist/runtime/edge-esm.js"
    },
    "./runtime/react-native": {
      "types": "./dist/runtime/react-native.d.ts",
      "require": "./dist/runtime/react-native.js",
      "import": "./dist/runtime/react-native.js",
      "default": "./dist/runtime/react-native.js"
    },
    "./generator-build": {
      "require": "./dist/generator-build/index.js",
      "import": "./dist/generator-build/index.js",
      "default": "./dist/generator-build/index.js"
    },
    "./sql": {
      "require": {
        "types": "./dist/sql.d.ts",
        "node": "./dist/sql.js",
        "default": "./dist/sql.js"
      },
      "import": {
        "types": "./dist/sql.d.ts",
        "node": "./dist/sql.mjs",
        "default": "./dist/sql.mjs"
      },
      "default": "./dist/sql.js"
    },
    "./*": "./dist/*"
  },
  "nx": {
    "targets": {
      "prisma-reset": {
        "executor": "nx:run-commands",
        "options": {
          "command": "npx prisma migrate reset --force",
          "cwd": "{projectRoot}"
        }
      },
      "prisma-migrate": {
        "executor": "nx:run-commands",
        "options": {
          "command": "npx prisma migrate dev --name dev",
          "cwd": "{projectRoot}"
        }
      },
      "prisma-generate": {
        "executor": "nx:run-commands",
        "options": {
          "command": "npx prisma generate",
          "cwd": "{projectRoot}"
        }
      },
      "prisma-seed": {
        "executor": "nx:run-commands",
        "options": {
          "command": "node ./scripts/seed-run.mjs",
          "cwd": "{projectRoot}"
        }
      },
      "update-content": {
        "executor": "@beezone/cli:update-content",
        "options": {
          "projectRoot": "{projectRoot}"
        }
      },
      "update-version": {
        "executor": "@beezone/cli:update-version",
        "options": {
          "projectRoot": "{projectRoot}"
        }
      }
    }
  },
  "scripts": {
    "postinstall": "node ./scripts/postinstall.mjs"
  },
  "peerDependencies": {
    "@prisma/client": "^6.12.0"
  },
  "devDependencies": {
    "prisma": "^6.12.0"
  }
}
