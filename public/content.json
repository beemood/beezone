[
  {
    "name": "@beezone/cli",
    "description": "Project generators, executors, and plugins",
    "version": "0.0.5",
    "publishConfig": {
      "access": "public",
      "tag": "latest"
    },
    "homepage": "https://beemood.github.io/beezone/libs/cli",
    "icon": "https://beemood.github.io/beezone/libs/cli/assets/favicon.png",
    "author": {
      "email": "robert.brightline@gmail.com",
      "name": "Robert Brightline",
      "url": "https://beemood.github.io"
    },
    "funding": ["https://cash.app/$puqlib"],
    "keywords": ["generator", "executor", "plugin"],
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      "./package.json": "./package.json",
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./doc": "./dist/plugins/doc/plugin.js",
      "./update-version": "./dist/plugins/update-version/plugin.js",
      "./update-content": "./dist/plugins/update-content/plugin.js",
      "./serve": "./dist/plugins/serve/plugin.js",
      "./build": "./dist/plugins/build/plugin.js"
    },
    "nx": {
      "targets": {
        "build": {
          "executor": "@nx/js:tsc",
          "outputs": ["{options.outputPath}"],
          "options": {
            "outputPath": "libs/cli/dist",
            "main": "libs/cli/src/index.ts",
            "tsConfig": "libs/cli/tsconfig.lib.json",
            "rootDir": "libs/cli/src",
            "generatePackageJson": false,
            "assets": [
              {
                "input": "./libs/cli/src",
                "glob": "**/!(*.ts)",
                "output": "."
              },
              {
                "input": "./libs/cli/src",
                "glob": "**/*.d.ts",
                "output": "."
              }
            ]
          }
        },
        "doc": {
          "executor": "nx:run-commands",
          "options": {
            "command": "npx typedoc --options {projectRoot}/typedoc.json  --entryPoints {projectRoot}/src/index.ts --out public/{projectRoot} --tsconfig {projectRoot}/tsconfig.lib.json"
          }
        },
        "update-content": {
          "executor": "@beezone/cli:update-content",
          "options": {
            "projectRoot": "{projectRoot}"
          }
        },
        "update-version": {
          "executor": "@beezone/cli:update-version",
          "options": {
            "projectRoot": "{projectRoot}"
          }
        }
      }
    },
    "dependencies": {
      "@beezone/errors": "workspace:*",
      "@beezone/fs": "workspace:*",
      "@beezone/types": "workspace:*",
      "@nx/devkit": "21.3.1",
      "commander": "^14.0.0",
      "tslib": "^2.3.0"
    },
    "bin": {
      "beezone": "./bin/beezone.mjs"
    },
    "files": ["dist", "!**/*.tsbuildinfo", "executors.json", "generators.json"],
    "executors": "./executors.json",
    "generators": "./generators.json"
  },
