      "@nestjs/throttler": "^6.4.0",
      "@swc/helpers": "~0.5.11"
    },
    "nx": {
      "sourceRoot": "apps/inventory/src",
      "targets": {
        "build": {
          "executor": "@nx/js:swc",
          "outputs": ["{options.outputPath}"],
          "options": {
            "outputPath": "{projectRoot}/dist",
            "main": "{projectRoot}/src/index.ts",
            "tsConfig": "{projectRoot}/tsconfig.lib.json",
            "skipTypeCheck": false,
            "stripLeadingPaths": true
          }
        },
        "build-watch": {
          "executor": "@nx/js:swc",
          "outputs": ["{options.outputPath}"],
          "options": {
            "outputPath": "{projectRoot}/dist",
            "main": "{projectRoot}/src/index.ts",
            "tsConfig": "{projectRoot}/tsconfig.lib.json",
            "skipTypeCheck": true,
            "stripLeadingPaths": true,
