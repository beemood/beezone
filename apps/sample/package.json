{
  "name": "@beezone/sample",
  "version": "0.2.1",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "nx": {
    "sourceRoot": "apps/sample/src",
    "targets": {
      "build": {
        "executor": "@nx/js:swc",
        "outputs": [
          "{options.outputPath}"
        ],
        "options": {
          "outputPath": "apps/sample/dist",
          "main": "apps/sample/src/index.ts",
          "tsConfig": "apps/sample/tsconfig.lib.json",
          "skipTypeCheck": false,
          "stripLeadingPaths": true
        }
      },
      "watch-build": {
        "executor": "@nx/js:swc",
        "outputs": [
          "{options.outputPath}"
        ],
        "options": {
          "outputPath": "apps/sample/dist",
          "main": "apps/sample/src/index.ts",
          "tsConfig": "apps/sample/tsconfig.lib.json",
          "skipTypeCheck": false,
          "stripLeadingPaths": true,
          "watch": true
        }
      },
      "watch-serve": {
        "executor": "nx:run-commands",
        "options": {
          "command": "node --watch --watch-path=src dist/main.js",
          "cwd": "{projectRoot}"
        }
      },
      "serve": {
        "dependsOn": [
          "watch-build",
          "watch-serve"
        ]
      }
    }
  },
  "dependencies": {
    "@beezone/bootstrap": "workspace:^",
    "@beezone/nest": "workspace:^",
    "@beezone/prisma-client": "^0.2.1",
    "@beezone/property": "workspace:^",
    "@beezone/sample-db": "workspace:^",
    "@beezone/types": "workspace:^",
    "@nestjs/common": "^11.1.3",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.3",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/platform-express": "^11.1.3",
    "@nestjs/schedule": "^6.0.0",
    "@nestjs/swagger": "^11.2.0",
    "@prisma/client": "^6.11.1",
    "@swc/helpers": "~0.5.11",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "helmet": "^8.1.0"
  },
  "devDependencies": {
    "prisma": "^6.11.1"
  }
}
