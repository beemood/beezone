{
  "name": "@beezone/validation",
  "description": "Composite property decorator for dto property validation",
  "version": "0.0.1",
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  },
  "homepage": "https://beemood.github.io/beezone/libs/validation",
  "icon": "https://beemood.github.io/beezone/libs/validation/assets/favicon.png",
  "author": {
    "email": "robert.brightline@gmail.com",
    "url": "https://beemood.github.io",
    "name": "Robert Brightline"
  },
  "keywords": [
    "dto",
    "validation"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "peerDependencies": {
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2"
  },
  "dependencies": {
    "@beezone/utils": "workspace:*",
    "@beezone/types": "workspace:*",
    "@swc/helpers": "~0.5.11"
  },
  "nx": {
    "sourceRoot": "libs/validation",
    "targets": {
      "whoami": {
        "executor": "nx:run-commands",
        "options": {
          "command": "echo {projectRoot}"
        }
      }
    }
  }
}
