{
  "name": "@beezone/validation",
  "description": "Input validation library built on top of `class-validator` and `class-transformer` to implement all validaitons operation with a single decorator `@Valiation({ ...options })`.",
  "version": "0.0.1",
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  },
  "homepage": "https://beemood.github.io/beezone/libs/validation",
  "icon": "https://beemood.github.io/beezone/libs/validation/assets/favicon.png",
  "author": {
    "email": "robert.brightline@gmail.com",
    "url": "https://beemood.github.io",
    "name": "Robert Brightline"
  },
  "keywords": [
    "dto",
    "validation"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "nx": {
    "sourceRoot": "libs/validation/src",
    "targets": {
      "build": {
        "executor": "@nx/js:swc",
        "outputs": [
          "{options.outputPath}"
        ],
        "options": {
          "outputPath": "libs/validation/dist",
          "main": "libs/validation/src/index.ts",
          "tsConfig": "libs/validation/tsconfig.lib.json",
          "skipTypeCheck": true,
          "stripLeadingPaths": true
        }
      }
    }
  },
  "peerDependencies": {
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2"
  },
  "dependencies": {
    "@swc/helpers": "~0.5.11"
  }
}
