{
  "name": "@beezone/property",
  "description": "Composite property decorator for dto properties",
  "version": "0.0.1",
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  },
  "homepage": "https://beemood.github.io/beezone/libs/property",
  "icon": "https://beemood.github.io/beezone/libs/property/assets/favicon.png",
  "author": {
    "email": "robert.brightline@gmail.com",
    "name": "Robert Brightline",
    "url": "https://beemood.github.io"
  },
  "keywords": [
    "- [ ] add keywords"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "peerDependencies": {
    "class-transformer": "^0.5.1"
  },
  "dependencies": {
    "@beezone/types": "workspace:*",
    "@beezone/validation": "workspace:*",
    "@nestjs/swagger": "^11.2.0",
    "@swc/helpers": "~0.5.11"
  },
  "nx": {
    "sourceRoot": "libs/property",
    "targets": {
      "whoami": {
        "executor": "nx:run-commands",
        "options": {
          "command": "echo {projectRoot}"
        }
      }
    }
  }
}
