{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "Project",
  "title": "",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "$default": {
        "$source": "argv",
        "index": 0
      },
      "x-prompt": "What name would you like to use?"
    },

    "projectType": {
      "type": "string",
      "description": "",
      "enum": ["lib", "cli", "api", "db"],
      "$default": {
        "$source": "argv",
        "index": 1
      },
      "x-prompt": "What projectType would you like to use?"
    }
  },
  "required": ["name"]
}
