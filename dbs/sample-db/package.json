{
  "name": "@beezone/sample-db",
  "version": "0.1.2",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "postinstall": "npx prisma generate"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "prisma",
    "env",
    "!**/*.tsbuildinfo"
  ],
  "nx": {
    "sourceRoot": "dbs/sample-db/src",
    "targets": {
      "build": {
        "executor": "nx:run-commands",
        "options": {
          "commands": [
            "npx prisma generate"
          ],
          "cwd": "{projectRoot}"
        }
      }
    }
  },
  "dependencies": {
    "@prisma/client": "^6.11.1",
    "@swc/helpers": "~0.5.11"
  },
  "devDependencies": {
    "prisma": "^6.11.1"
  }
}
